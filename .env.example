# Application Environment
APP_ENV=development

# Server Configuration
PORT=8080

# Database
DATABASE_URL=postgres://user:password@localhost:5432/wtf_backend?sslmode=disable

DB_USER=user
DB_PASS=password
DB_NAME=wtf_backend

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Rate Limiting
REQUESTS_PER_MINUTE=10

# Background Workers
# Set to false to disable background job processing in this instance
# Useful for running separate API and worker processes
ENABLE_WORKERS=true
